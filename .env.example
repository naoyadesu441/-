# Stage 1 (リサーチ自動集約) で必要な環境変数。
# ローカルでは `.env` にコピーして値を入れる。GitHub Actions では同名のシークレットを登録する。
# いずれも無料枠のみ。従量課金は一切発生しない設計。

# Google AI Studio の API キー（Gemini 無料枠。課金は有効化しないこと）
GEMINI_API_KEY=

# Discord の Incoming Webhook URL（チャンネル設定 → 連携サービス → ウェブフック）
DISCORD_WEBHOOK_URL=

# Notion インテグレーションの Internal Integration Token（secret_ で始まる）
NOTION_TOKEN=

# 投入先 Notion データベースの ID（DB を開いた URL の 32 桁英数字）
NOTION_DATABASE_ID=
